{
	"name": "@wattmaven/docs",
	"version": "0.2.1",
	"private": true,
	"type": "module",
	"scripts": {
		"install:hooks": "lefthook install",
		"commit": "commit",
		"type-check": "tsc --noEmit",
		"format:check": "biome check .",
		"format:fix": "biome check . --write",
		"format:fix-unsafe": "biome check . --write --unsafe",
		"declutter": "knip --no-exit-code",
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"test:unit": "vitest run --passWithNoTests",
		"test:unit:watch": "vitest --passWithNoTests",
		"test:e2e": "playwright test --pass-with-no-tests",
		"test:e2e:report": "playwright show-report",
		"test": "pnpm test:unit",
		"pre-commit-tasks": "turbo build type-check test",
		"ci:version": "changeset version && pnpm format:fix",
		"ci:publish": "changeset publish",
		"clean": "rimraf coverage node_modules .astro .turbo playwright-report test-results"
	},
	"dependencies": {
		"@astrojs/check": "^0.9.4",
		"@astrojs/starlight": "^0.25.5",
		"@astrojs/starlight-tailwind": "^2.0.3",
		"@astrojs/tailwind": "^5.1.2",
		"@inox-tools/star-warp": "^0.1.4",
		"@sentry/astro": "^8.35.0",
		"@t3-oss/env-core": "^0.11.1",
		"astro": "^4.15.3",
		"rehype-mermaid": "^3.0.0",
		"sharp": "^0.32.5",
		"starlight-links-validator": "^0.12.3",
		"tailwindcss": "^3.4.14",
		"typescript": "^5.6.3",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.3",
		"@changesets/cli": "2.27.9",
		"@commitlint/cli": "19.5.0",
		"@commitlint/config-conventional": "19.5.0",
		"@commitlint/prompt-cli": "19.5.0",
		"@commitlint/types": "19.5.0",
		"@playwright/test": "^1.48.2",
		"jsdom": "^25.0.1",
		"knip": "^5.33.3",
		"lefthook": "^1.7.18",
		"rimraf": "6.0.1",
		"turbo": "2.1.3",
		"vite": "^5.4.10",
		"vitest": "^2.1.3"
	},
	"packageManager": "pnpm@9.7.0"
}
